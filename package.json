{
  "name": "forge3d",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@11.16.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm run dev:server\" \"pnpm run dev:web\"",
    "dev:web": "vite",
    "dev:server": "node --env-file-if-exists=.env --watch server/index.js",
    "server": "node --env-file-if-exists=.env server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "cf:build": "npm run build",
    "cf:deploy": "npm run build && node scripts/prepare-cloudflare-assets.mjs && npx wrangler deploy",
    "cf:d1:migrate": "npx wrangler d1 migrations apply forge3d --remote",
    "cf:release": "npm run test && npm run cf:d1:migrate && npm run cf:deploy",
    "test": "node --test server/*.test.js src/*.test.js"
  },
  "dependencies": {
    "@google/model-viewer": "^4.3.1",
    "@tiptap/core": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/vue-3": "^3.28.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "dompurify": "^3.4.12",
    "elkjs": "^0.11.1",
    "marked": "^18.0.7",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^9.2.0",
    "tailwindcss": "^4.3.3",
    "vite": "^7.0.4"
  }
}
